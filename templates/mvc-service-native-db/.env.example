# Environment variables for the MVC service (native DB drivers)
ENV=development
APP_NAME=mvc-service-native-db

# Native DB backend selected by config/connection_db.py
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite

# SQLite (when DB_BACKEND=sqlite)
DB_PATH=./data/app.db

# All other backends — set DB_DSN to skip the individual fields
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432        # varies by backend: postgresql=5432, mysql/mariadb=3306, mssql=1433, oracle=1521
DB_NAME=app
DB_DSN=

# Oracle only — service name replaces DB_NAME
DB_SERVICE=XEPDB1

# SQL Server only — ODBC driver name used to build the pyodbc connection string
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# SQL Server only — auth mode: "sql" (UID/PWD, default) or "aad" (Azure AD Interactive)
DB_MSSQL_AUTH=sql

# SQL Server only — TLS options (ODBC Driver 18 defaults Encrypt=yes). Leave unset for the
# driver default; set when connecting to a server with a self-signed certificate. Accepts
# yes/no/true/false/1/0/on/off (normalised), plus driver tokens (strict/mandatory/optional).
# DB_ENCRYPT=yes
# DB_TRUST_SERVER_CERTIFICATE=yes
