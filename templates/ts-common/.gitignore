node_modules/
dist/

# Git-diff offline-sync exports (present only when scaffolded without GitHub)
/git_diffs/

# Repo→LLM context dump generated by `npm run context:export`
/repo_context.txt

# Scaffoldable lessons — local working copies only; the canonical, cross-project
# stores live globally in ~/.claude/memory/lessons/ (templates) and
# ~/.claude/memory/lessons-dotfiles/ (the dotfiles-dev Claude toolchain). Never committed here.
docs/blueprintx-lessons.md
docs/dotfiles-dev-lessons.md

.env
.env.local
*.log
.DS_Store

# Claude Code machine-local settings + its mid-save temp siblings. The
# `.tmp.<pid>.<hash>` file is written briefly during a save; a `git add -A` that
# races that window would otherwise sweep it into a commit.
.claude/settings.local.json
.claude/settings.local.json.tmp.*
coverage/
.nyc_output/

# Playwright — keep test specs and committed visual baselines (*-snapshots/),
# ignore generated reports and run artifacts.
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/
