# Environment variables for the service
# ENV: dev or prd (also development/production/produção/etc.; case/accent/space-insensitive)
ENV=development
APP_NAME=ddd-service-native-db

# SQL-backed backends — for use with chassis.db_schema
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite

# SQLite (when DB_BACKEND=sqlite)
DB_PATH=./data/app.db

# All other backends — set DB_DSN to skip individual fields
DB_USER=app_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432        # varies by backend: postgresql=5432, mysql/mariadb=3306, mssql=1433, oracle=1521
DB_NAME=app_db
DB_DSN=

# PostgreSQL schema — used when DB_BACKEND=postgresql
DB_SCHEMA=public

# Oracle only — service name replaces DB_NAME
DB_SERVICE=XEPDB1

# SQL Server only — ODBC driver name used to build the pyodbc connection string
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Database admin UI (pgAdmin / phpMyAdmin — only when docker-compose is included)
ADMIN_EMAIL=admin@app.local
ADMIN_PASSWORD=changeme
ADMIN_PORT=5050
