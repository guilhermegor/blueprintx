# Environment variables for the service
ENV=development
APP_NAME=ddd-service-native-db

# SQL-backed backends — for use with chassis.db_schema
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite
DATA_DIR=./data
SQLITE_PATH=app.db

# Schema-less backends — for use with chassis.db_wschema
# Available options: json, csv, joblib
STORAGE_BACKEND=json
DB_FILE_JSON=records.json
DB_FILE_CSV=records.csv
JOBLIB_DIR=artifacts
JOBLIB_SECRET_KEY=   # optional: set a hex string in production to enable HMAC tamper-detection

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
# Use POSTGRES_DSN to override the composed DSN above
POSTGRES_DSN=

# MariaDB
MARIADB_USER=user
MARIADB_PASSWORD=password
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DB=app
# Use MARIADB_DSN to override the composed DSN above
MARIADB_DSN=

# MySQL
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=app
# Use MYSQL_DSN to override the composed DSN above
MYSQL_DSN=

# MSSQL (SQL Server)
MSSQL_USER=sa
MSSQL_PASSWORD=password
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=app
# Use MSSQL_DSN to override the composed DSN above
MSSQL_DSN=

# Oracle
ORACLE_USER=user
ORACLE_PASSWORD=password
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
# Use ORACLE_DSN to override the composed DSN above
ORACLE_DSN=

