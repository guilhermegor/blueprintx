# Environment variables for the service
ENV=development
APP_NAME=ddd-service-native-db

# SQL-backed backends — for use with chassis.db_schema
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite

# SQLite (when DB_BACKEND=sqlite)
DB_PATH=./data/app.db

# All other backends — set DB_DSN to skip individual fields
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432        # varies by backend: postgresql=5432, mysql/mariadb=3306, mssql=1433, oracle=1521
DB_NAME=app
DB_DSN=

# Oracle only — service name replaces DB_NAME
DB_SERVICE=XEPDB1

# Schema-less backends — for use with chassis.db_wschema
# Available options: json, csv, joblib
STORAGE_BACKEND=json
DATA_DIR=./data
DB_FILE_JSON=records.json
DB_FILE_CSV=records.csv
JOBLIB_DIR=artifacts
JOBLIB_SECRET_KEY=   # optional: set a hex string in production to enable HMAC tamper-detection

