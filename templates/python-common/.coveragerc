[run]
source = src/
omit =
    src/chassis/*
    src/capabilities/example_feature/*
    src/capabilities/*/infrastructure/*
    src/capabilities/*/domain/enums.py
    src/app/*
    src/config/*
    src/main.py
    src/utils/*

[report]
# Single source of truth for the coverage floor — read by pytest-cov in both the
# pre-commit `coverage-check` hook and the CI coverage gate (no duplicated literal).
fail_under = 80
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    @abstractmethod
    \.\.\.
