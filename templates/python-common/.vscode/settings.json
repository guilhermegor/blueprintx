{
	// Default to the POSIX venv interpreter (Linux/macOS). There is no
	// OS-portable way to express this key, so if the project runs on WINDOWS,
	// comment the line below and uncomment the Windows one beneath it.
	"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
	// "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
	"python.terminal.activateEnvironment": true,
	"python.analysis.extraPaths": ["src"],
	"python.testing.pytestEnabled": true,
	"python.testing.pytestArgs": ["tests/unit"],
	"[python]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4
	},
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	// These extension-less dotfiles are INI-format tool configs, not Python —
	// declare the language so Pylance stops analysing them and reporting false
	// "X is not defined" errors on their section keys.
	"files.associations": {
		".gitlint": "ini",
		".codespellrc": "ini",
		".pydocstyle": "ini"
	},
	"python-envs.defaultEnvManager": "ms-python.python:poetry",
	"python-envs.defaultPackageManager": "ms-python.python:poetry"
}
