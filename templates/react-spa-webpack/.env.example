# Environment variables for the React SPA (build-time)
#
# Webpack inlines a fixed allow-list of these into the bundle via DefinePlugin
# (see webpack.config.js). Copy this file to .env and adjust as needed — .env
# is git-ignored, .env.example is committed as the documented template.

# Build mode — "development" (HMR, readable class names) or "production"
# (minified, hashed CSS). The npm scripts set this via cross-env; override
# here only for ad-hoc local builds.
NODE_ENV=development

# Base public path the bundle is served from. Default "/" works for local dev
# and root-served hosts. GitHub Pages project sites live under "/<repo-name>/",
# so the deploy workflow sets PUBLIC_PATH=/<repo-name>/ and DefinePlugin inlines
# it as process.env.PUBLIC_PATH for react-router's <BrowserRouter basename>.
PUBLIC_PATH=/
