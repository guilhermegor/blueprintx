# Environment variables for the React SPA (build-time)
#
# Webpack inlines these into the bundle via DefinePlugin (see webpack.config.js):
# NODE_ENV and PUBLIC_PATH are handled specially; every other KEY=VALUE below is
# exposed to app code as process.env.KEY. A real process env var (CI, or a Docker
# BuildKit secret mounted at build time) overrides the value committed here.
# Copy this file to .env and adjust — .env is git-ignored, .env.example is the
# committed template.

# Build mode — "development" (HMR, readable class names) or "production"
# (minified, hashed CSS). The npm scripts set this via cross-env; override
# here only for ad-hoc local builds.
NODE_ENV=development

# Base public path the bundle is served from. Default "/" works for local dev
# and root-served hosts. GitHub Pages project sites live under "/<repo-name>/",
# so the deploy workflow sets PUBLIC_PATH=/<repo-name>/ and DefinePlugin inlines
# it as process.env.PUBLIC_PATH for react-router's <BrowserRouter basename>.
PUBLIC_PATH=/

# Custom build-time vars: any key here is inlined as process.env.<KEY>. Read it
# in app code as `process.env.API_KEY`. Keep secrets out of git — set real
# values in your local .env (ignored) or pass them via a Docker BuildKit secret.
# API_KEY=
