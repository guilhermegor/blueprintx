# Environment variables for the MVC service (SQLAlchemy ORM)
ENV=development
APP_NAME=mvc-service-orm-db

# Base directory for run outputs (log, json, report). Per-machine — may be a
# relative path, an absolute POSIX path, or a Windows UNC path. Outputs land under
# <OUTPUT_DIR>/daily_infos/<YYYY-MM-DD>/. Examples:
#   OUTPUT_DIR=logs
#   OUTPUT_DIR=/var/log/myapp
#   OUTPUT_DIR=\\server\share\Team\DAILY INFOS
OUTPUT_DIR=logs

# SQLAlchemy database backend selected by model/conexao_db.py
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite

# SQLite (when DB_BACKEND=sqlite)
DB_PATH=./data/app.db

# All other backends — set DB_DSN to skip the individual fields
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432        # varies by backend: postgresql=5432, mysql/mariadb=3306, mssql=1433, oracle=1521
DB_NAME=app
DB_DSN=

# Oracle only — service name replaces DB_NAME
DB_SERVICE=XEPDB1

# Set to true to echo SQL statements (debug mode)
SQL_ECHO=false
