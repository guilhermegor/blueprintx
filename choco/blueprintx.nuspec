<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>blueprintx</id>
    <version>0.1.3</version>
    <title>BlueprintX</title>
    <authors>guilhermegor</authors>
    <projectUrl>https://github.com/guilhermegor/blueprintx</projectUrl>
    <licenseUrl>https://github.com/guilhermegor/blueprintx/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Make + bash scaffolding tool for opinionated Python project skeletons. Requires Git for Windows (bash.exe on PATH) or WSL.</description>
    <tags>scaffolding python ddd blueprint cli</tags>
    <dependencies>
      <dependency id="git" version="2.0" />
    </dependencies>
  </metadata>
</package>
